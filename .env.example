# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# SPOTIFY_CLIENT_ID: Required for fetching music metadata from Spotify.
SPOTIFY_CLIENT_ID="MY_SPOTIFY_CLIENT_ID"

# SPOTIFY_CLIENT_SECRET: Required for fetching music metadata from Spotify.
SPOTIFY_CLIENT_SECRET="MY_SPOTIFY_CLIENT_SECRET"
